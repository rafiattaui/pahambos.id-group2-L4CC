{
  "openapi": "3.0.0",
  "info": {
    "title": "Quiz and User API",
    "description": "Combined API documentation for Quiz management and User profile services.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Base Server"
    }
  ],
  "tags": [{ "name": "Auth" }, { "name": "Quiz" }, { "name": "User" }],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Enter your bearer token in the format: <token>"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "required": [
          "id",
          "email",
          "name",
          "image",
          "emailVerified",
          "role",
          "createdAt"
        ],
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "name": { "type": "string" },
          "image": { "type": "string" },
          "emailVerified": { "type": "boolean" },
          "role": { "type": "string", "enum": ["Learner", "Educator"] },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "Quiz": {
        "type": "object",
        "required": [
          "id",
          "title",
          "createdBy",
          "createdAt",
          "numQuestions",
          "category"
        ],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "createdBy": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "numQuestions": { "type": "integer" },
          "category": { "type": "string" }
        }
      },
      "QuizDetailed": {
        "allOf": [
          { "$ref": "#/components/schemas/Quiz" },
          {
            "type": "object",
            "properties": {
              "questions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "quizId": { "type": "string" },
                    "order": { "type": "integer" },
                    "question": { "type": "string" },
                    "answers": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "correctAnswer": { "type": "integer" }
                  }
                }
              }
            }
          }
        ]
      },
      "QuizList": {
        "type": "object",
        "required": ["data", "nextCursor"],
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Quiz" }
          },
          "nextCursor": { "type": "string", "nullable": true }
        }
      }
    }
  },
  "paths": {
    "/api/auth/sign-up/email": {
      "post": {
        "summary": "Register new user",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "name"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 8 },
                  "name": { "type": "string" },
                  "image": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "User created" }
        }
      }
    },
    "/api/auth/sign-in/email": {
      "post": {
        "summary": "Login with email",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Successful login" }
        }
      }
    },
    "/api/quiz": {
      "get": {
        "summary": "Get Quiz List",
        "tags": ["Quiz"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "sortBy",
            "in": "query",
            "schema": { "type": "string", "enum": ["asc", "desc"] }
          },
          {
            "name": "tags",
            "in": "query",
            "style": "form",
            "explode": true,
            "schema": { "type": "array", "items": { "type": "string" } }
          },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QuizList" }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Quiz",
        "tags": ["Quiz"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["quiz", "questions"],
                "properties": {
                  "quiz": {
                    "type": "object",
                    "required": ["title", "description", "category"],
                    "properties": {
                      "title": { "type": "string" },
                      "description": { "type": "string" },
                      "category": { "type": "string" }
                    }
                  },
                  "questions": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "order",
                        "question",
                        "answers",
                        "correctAnswer"
                      ],
                      "properties": {
                        "order": { "type": "integer" },
                        "question": { "type": "string" },
                        "answers": {
                          "type": "array",
                          "items": { "type": "string" }
                        },
                        "correctAnswer": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Quiz created" }
        }
      }
    },
    "/api/quiz/{id}": {
      "get": {
        "summary": "Get Detailed Quiz",
        "tags": ["Quiz"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QuizDetailed" }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete a quiz",
        "tags": ["Quiz"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Quiz successfully deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "success": { "type": "boolean" } }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Quiz not found" }
        }
      }
    },
    "/api/user": {
      "get": {
        "summary": "Get User Profile",
        "tags": ["User"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Edit User Profile",
        "tags": ["User"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": { "type": "string" },
                  "name": { "type": "string" },
                  "role": { "type": "string", "enum": ["Learner", "Educator"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "User updated" }
        }
      },
      "delete": {
        "summary": "Delete Account",
        "tags": ["User"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Account deleted" }
        }
      }
    }
  }
}
