  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "QuizListQuerySchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "number",
            "minimum": 1,
            "maximum": 20,
            "default": 10
          },
          "cursor": {
            "type": "string"
          },
          "sortBy": {
            "type": "string",
            "enum": [
              "asc",
              "desc"
            ],
            "default": "asc"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CategoryEnum"
            }
          }
        },
        "required": [
          "limit",
          "sortBy"
        ]
      },
      "QuizListResponseSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PublicQuizSchema"
            }
          },
          "nextCursor": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "data"
        ]
      },
      "QuizDetailResponseSchema": {
        "type": "object",
        "properties": {
          "quiz": {
            "type": "object",
            "properties": {
              "questions": {
                "type": "array",
