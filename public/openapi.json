            "type": "string",
            "minLength": 5
          },
          "description": {
            "type": "string"
          },
          "category": {
            "$ref": "#/components/schemas/CategoryEnum"
          },
          "numQuestions": {
            "type": "string",
            "minimum": 0
          }
