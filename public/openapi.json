              "type": "string",
              "minLength": 2
            },
            "minItems": 2
          }
        },
        "required": [
          "id",
          "quizId",
          "order",
          "question",
          "answers"
        ]
      },
      "CreateQuestionSchema": {
        "type": "object",
        "properties": {
          "order": {
            "type": "string",
            "minimum": 0
