                }
              }
            },
            "required": [
              "questions"
            ]
          }
        },
        "required": [
          "quiz"
        ]
      },
      "QuizQuestionSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "quizId": {
            "type": "string"
          },
          "order": {
            "type": "string",
            "minimum": 0
          },
          "question": {
            "type": "string",
            "minLength": 5,
            "maxLength": 100
          },
          "answers": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 2
            },
            "minItems": 2
          },
          "correctAnswer": {
            "type": "string",
            "minimum": 0
          }
        },
        "required": [
          "id",
          "quizId",
          "order",
          "question",
          "answers",
          "correctAnswer"
        ]
      },
      "CategoryEnum": {
        "type": "string",
        "enum": [
          "Mathematics",
          "Science",
          "History",
          "Language",
          "Geography",
          "Technology",
          "General"
        ]
      },
